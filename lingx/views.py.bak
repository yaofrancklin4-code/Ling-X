        })
    
    context = {
        'games': games_with_unlock,
        'user_scores': user_scores,
    }
    return render(request, 'games.html', context)

@login_required
def save_game_score(request):
    """Enregistre le score d'un jeu et met à jour le profil utilisateur"""
    if request.method != 'POST':
        return JsonResponse({'error': 'Method not allowed'}, status=405)
    
    try:
        import json
        data = json.loads(request.body)
        game_id = data.get('game_id')
        score = data.get('score')
        xp_earned = data.get('xp_earned')
        
        # Valider les données
        if not all([game_id, score is not None, xp_earned is not None]):
            return JsonResponse({'error': 'Missing required fields'}, status=400)
        
        # Récupérer le jeu
        game = get_object_or_404(MiniGame, id=game_id)
        
        # Créer le GameScore
        game_score = GameScore.objects.create(
            user=request.user,
            game=game,
            score=score,
            points_earned=xp_earned
        )
        
        # Mettre à jour le profil utilisateur
        profile = request.user.profile
        profile.total_points += xp_earned
        
        # Calculer le nouveau niveau (1 niveau tous les 100 XP)
        profile.level = (profile.total_points // 100) + 1
        profile.save()
        
        return JsonResponse({
            'success': True,
            'message': f'Score enregistré! +{xp_earned} XP',
            'new_total_points': profile.total_points,
            'new_level': profile.level,
            'game_score_id': game_score.id
        })
    
    except json.JSONDecodeError:
        return JsonResponse({'error': 'Invalid JSON'}, status=400)
    except Exception as e:
        return JsonResponse({'error': str(e)}, status=500)

@login_required
def game_play(request, game_id):
    """Affiche l'interface de jeu avec les vocabulaires appropriés"""
    game = get_object_or_404(MiniGame, id=game_id)
    
    # Récupérer les vocabulaires pour le jeu
    # Si le jeu est lié à une leçon, utiliser son vocabulaire
    if game.lesson:
        vocabularies = Vocabulary.objects.filter(
            lesson=game.lesson
        ).order_by('?')[:20]
    else:
        # Sinon, prendre du vocabulaire au hasard
        vocabularies = Vocabulary.objects.order_by('?')[:20]
    
    # Préparer les paires pour JavaScript {baoule, french}
    vocabulary_pairs = [
        {
            'baoule': v.word_baule,
            'french': v.word_french,
            'pronunciation': v.pronunciation or ''
        }
        for v in vocabularies
    ]
    
    # Convertir en JSON sécurisé pour le template
    import json
    vocabulary_pairs_json = json.dumps(vocabulary_pairs)
    
    context = {
        'game': game,
        'vocabulary_pairs': vocabulary_pairs_json,
    }
    return render(request, 'game_play.html', context)

@login_required
def leaderboard_view(request):
    period = request.GET.get('period', 'all_time')
    
    if period == 'daily':
        start_date = timezone.now().date()
        end_date = start_date
    elif period == 'weekly':
        start_date = timezone.now().date() - timedelta(days=7)
        end_date = timezone.now().date()
    elif period == 'monthly':
        start_date = timezone.now().date() - timedelta(days=30)
        end_date = timezone.now().date()
    else:
        start_date = None
        end_date = None
    
    if start_date:
        top_users = UserProfile.objects.filter(
            user__lesson_progress__updated_at__date__range=[start_date, end_date]
        ).annotate(
            period_points=Sum('user__lesson_progress__score')
        ).order_by('-period_points')[:50]
    else:
        top_users = UserProfile.objects.order_by('-total_points')[:50]
    
    context = {
        'top_users': top_users,
        'period': period,
    }
    return render(request, 'leaderboard.html', context)

