@login_required
def dictionary_stats(request):
    """Affiche les statistiques du dictionnaire"""
    total_words = Vocabulary.objects.count()
    total_lessons = Lesson.objects.count()
    total_categories = Category.objects.count()
    total_quizzes = Quiz.objects.count()
    
    # Mots par catégorie
    words_by_category = Category.objects.annotate(
        word_count=Count('lessons__vocabularies')
    ).order_by('-word_count')
    
    # Leçons avec le plus de mots
    lessons_with_words = Lesson.objects.annotate(
        vocab_count=Count('vocabularies'),
        quiz_count=Count('quizzes')
    ).order_by('-vocab_count')[:10]
    
    context = {
        'total_words': total_words,
        'total_lessons': total_lessons,
        'total_categories': total_categories,
        'total_quizzes': total_quizzes,
        'words_by_category': words_by_category,
        'lessons_with_words': lessons_with_words,
    }
    return render(request, 'dictionary_stats.html', context)

@login_required
def dictionary_view(request):
    """Affiche le dictionnaire Baoulé-Français (16 mots officiels uniquement)."""
    from .models import DictionaryEntry
    query     = request.GET.get('q', '').strip()
    direction = request.GET.get('direction', 'fr_to_baoule')

    entries = DictionaryEntry.objects.all()

    if query:
        if direction == 'baule_to_fr':
            entries = entries.filter(
                Q(word_baule__icontains=query) | Q(word_french__icontains=query)
            )
        else:
            entries = entries.filter(
                Q(word_french__icontains=query) | Q(word_baule__icontains=query)
            )

    entries = entries.order_by('word_baule')

    context = {
        'query':        query,
        'direction':    direction,
        'vocabularies': entries,           # nom conservé pour compatibilité template
        'total_words':  DictionaryEntry.objects.count(),
    }
    return render(request, 'dictionnaire.html', context)
@login_required
@api_view(['POST'])
def submit_quiz_answer(request):
    """Endpoint AJAX pour soumettre une réponse à une question et attribuer les points immédiatement."""
    try:
        data = request.data if hasattr(request, 'data') else request.POST
        quiz_id = int(data.get('quiz_id'))
        choice_id = int(data.get('choice_id'))
    except Exception:
        return Response({'error': 'Données invalides'}, status=400)

    quiz = get_object_or_404(Quiz, id=quiz_id)
    try:
        choice = QuizChoice.objects.get(id=choice_id, quiz=quiz)
    except QuizChoice.DoesNotExist:
        return Response({'error': 'Choix introuvable'}, status=404)

    is_correct = choice.is_correct
    points = quiz.points if is_correct else 0

    attempt = QuizAttempt.objects.create(
        user=request.user,
        quiz=quiz,
        selected_choice=choice,
        is_correct=is_correct,
        points_earned=points
    )

    # Mettre à jour progression/score utilisateur
    profile = request.user.profile
    profile.add_points(points)

    return Response({
        'success': True,
        'is_correct': is_correct,
        'points_awarded': points,
        'new_total_points': profile.total_points,
    })


@login_required
@api_view(['POST'])
def submit_game_points(request):
    """Endpoint AJAX pour attribuer des points progressifs pendant une partie (appel JS)."""
    try:
        data = request.data if hasattr(request, 'data') else request.POST
        points = int(data.get('points', 0))
    except Exception:
        return Response({'error': 'Données invalides'}, status=400)

    if points <= 0:
        return Response({'success': False, 'message': 'Aucun point à attribuer'})

    profile = request.user.profile
    profile.add_points(points)

    return Response({'success': True, 'points_awarded': points, 'new_total_points': profile.total_points})

@login_required
def vocabulary_detail(request, vocab_id):
    """Détail d'un mot de vocabulaire"""
    vocabulary = get_object_or_404(Vocabulary, id=vocab_id)
    
    # Trouver des mots similaires
    similar_words = Vocabulary.objects.filter(
        lesson=vocabulary.lesson
    ).exclude(id=vocab_id)[:5]
    
    context = {
        'vocabulary': vocabulary,
        'similar_words': similar_words,
    }
    return render(request, 'vocabulary_detail.html', context)

# ============= RÉVISION SPACED REPETITION =============

@login_required
def review_vocabulary(request):
    """Système de révision SRS (Spaced Repetition System)"""
    user = request.user
    
    # Récupérer les mots à réviser
    today = timezone.now().date()
    vocabularies_to_review = Vocabulary.objects.filter(
        lesson__in=LessonProgress.objects.filter(
            user=user, is_completed=True
        ).values_list('lesson', flat=True)
    ).order_by('?')[:10]
    
    if request.method == 'POST':
        vocab_id = request.POST.get('vocab_id')
        difficulty = request.POST.get('difficulty')  # easy, medium, hard
        
        vocab = get_object_or_404(Vocabulary, id=vocab_id)
        
        # Enregistrer la révision
        review = VocabularyReview.objects.create(
            user=user,
            vocabulary=vocab,
            difficulty_rating=difficulty,
            reviewed_at=timezone.now()
        )
        
        messages.success(request, 'Mot révisé!')
        return redirect('review_vocabulary')
    
    context = {
        'vocabularies': vocabularies_to_review,
    }
    return render(request, 'review_vocabulary.html', context)

# ============= STATS UTILISATEUR =============

@login_required  
def user_stats(request):
    """Statistiques d'apprentissage de l'utilisateur"""
    user = request.user
    
    # Statistiques globales
    total_lessons_started = LessonProgress.objects.filter(user=user).count()
    total_lessons_completed = LessonProgress.objects.filter(user=user, is_completed=True).count()
    total_quizzes_attempted = QuizAttempt.objects.filter(user=user).count()
    total_points = user.profile.total_points
    
    # Taux de réussite
    correct_quizzes = QuizAttempt.objects.filter(user=user, is_correct=True).count()
    success_rate = (correct_quizzes / total_quizzes_attempted * 100) if total_quizzes_attempted > 0 else 0
    
    # Progrès par catégorie
    category_progress = []
    for category in Category.objects.all():
        completed = LessonProgress.objects.filter(
            user=user,
            lesson__category=category,
            is_completed=True
        ).count()
        total = Lesson.objects.filter(category=category).count()
        if total > 0:
            category_progress.append({
                'category': category,
                'completed': completed,
                'total': total,
                'percentage': int((completed / total) * 100)
            })
    
    # Graphique d'activité (derniers 30 jours)
    from django.db.models import Count
    last_30_days = timezone.now() - timedelta(days=30)
    activity_data = LessonProgress.objects.filter(
        user=user,
        updated_at__gte=last_30_days
    ).extra(
        select={'date': 'DATE(updated_at)'}
    ).values('date').annotate(
        count=Count('id')
    ).order_by('date')
    
    context = {
        'total_lessons_started': total_lessons_started,
        'total_lessons_completed': total_lessons_completed,
        'total_quizzes_attempted': total_quizzes_attempted,
        'total_points': total_points,
        'success_rate': int(success_rate),
        'category_progress': category_progress,
        'activity_data': list(activity_data),
    }
    return render(request, 'user_stats.html', context)


# ============= GAMIFICATION & NOTIFICATIONS =============

@login_required
def notifications_view(request):
    """Affiche toutes les notifications de l'utilisateur"""
    from lingx.services import GamificationService
    
    page = request.GET.get('page', 1)
    unread_only = request.GET.get('filter') == 'unread'
    
    notifications_query = UserNotification.objects.filter(user=request.user)
    if unread_only:
        notifications_query = notifications_query.filter(is_read=False)
    
    from django.core.paginator import Paginator
    paginator = Paginator(notifications_query.order_by('-created_at'), 15)
    page_obj = paginator.get_page(page)
    
    unread_count = UserNotification.objects.filter(user=request.user, is_read=False).count()
    
    context = {
        'notifications': page_obj,
        'unread_count': unread_count,
        'unread_only': unread_only,
    }
    return render(request, 'notifications.html', context)

@login_required
def mark_notification_read(request, notification_id):
    """Marque une notification comme lue"""
    notification = get_object_or_404(UserNotification, id=notification_id, user=request.user)
    notification.is_read = True
    notification.read_at = timezone.now()
    notification.save()
    
    next_url = request.GET.get('next', 'notifications')
    return redirect(next_url)

@login_required
def daily_reward_view(request):
    """Revendique la récompense quotidienne"""
    from lingx.services import GamificationService
    
    if request.method == 'POST':
        reward, message = GamificationService.claim_daily_reward(request.user)
        if reward:
            messages.success(request, message)
        else:
            messages.info(request, message)
        return redirect('dashboard')
    
    # Vérifier si une récompense est disponible
    from datetime import date
    today = date.today()
    reward_today = DailyReward.objects.filter(user=request.user, reward_date=today).first()
    
    streak = UserStreak.objects.filter(user=request.user).first()
    
    context = {
        'reward_today': reward_today,
        'streak': streak,
    }
    return render(request, 'daily_reward.html', context)

@login_required
def achievements_view(request):
    """Affiche les achievements de l'utilisateur"""
    user_achievements = UserAchievement.objects.filter(user=request.user).select_related('achievement').order_by('-unlocked_at')
    
    # Tous les achievements
    all_achievements = Achievement.objects.all().order_by('category')
    
    # Achievements non débloqués
    unlocked_ids = UserAchievement.objects.filter(user=request.user).values_list('achievement_id', flat=True)
    locked_achievements = Achievement.objects.exclude(id__in=unlocked_ids).order_by('category')
    
    context = {
        'user_achievements': user_achievements,
        'locked_achievements': locked_achievements,
    }
    return render(request, 'achievements.html', context)

@login_required
def gamification_dashboard(request):
    """Dashboard de gamification complet"""
    from lingx.services import GamificationService
    
    user = request.user
    profile = user.profile
    
    # Notifications récentes
    recent_notifications = UserNotification.objects.filter(user=user).order_by('-created_at')[:5]
    unread_count = UserNotification.objects.filter(user=user, is_read=False).count()
    
    # Streak
    streak = UserStreak.objects.filter(user=user).first()
    
    # Récompense quotidienne
    from datetime import date
    today = date.today()
    reward_today = DailyReward.objects.filter(user=user, reward_date=today).first()
    
    # Achievements récents
    recent_achievements = UserAchievement.objects.filter(user=user).order_by('-unlocked_at')[:4]
    
    # Progression vers le prochain niveau
    next_level_points = (profile.level) * 100
    current_level_points = (profile.level - 1) * 100
    points_in_level = profile.total_points - current_level_points
    points_for_level = next_level_points - current_level_points
    level_progress = int((points_in_level / points_for_level) * 100) if points_for_level > 0 else 0
    
    context = {
        'profile': profile,
        'recent_notifications': recent_notifications,
        'unread_count': unread_count,
        'streak': streak,
        'reward_today': reward_today,
        'recent_achievements': recent_achievements,
        'level_progress': level_progress,
        'next_level_points': next_level_points,
    }
    return render(request, 'gamification_dashboard.html', context)

# ============= API REST VIEWSETS =============

class CategoryViewSet(viewsets.ReadOnlyModelViewSet):
    queryset = Category.objects.all()
    serializer_class = CategorySerializer
    permission_classes = [AllowAny]

class LessonViewSet(viewsets.ReadOnlyModelViewSet):
    queryset = Lesson.objects.all()
    serializer_class = LessonSerializer
    permission_classes = [IsAuthenticated, IsLessonUnlockedPermission]
    
    @action(detail=True, methods=['get'])
    def vocabularies(self, request, pk=None):
        lesson = self.get_object()
        # Vérifier l'accès à la leçon avant de retourner le vocabulaire
        if not is_lesson_unlocked_for_user(request.user, lesson):
            return Response(
                {'detail': 'Vous n\'avez pas accès au vocabulaire de cette leçon.'},
                status=status.HTTP_403_FORBIDDEN
            )
        vocabularies = lesson.vocabularies.all()
        serializer = VocabularySerializer(vocabularies, many=True)
        return Response(serializer.data)
    
    @action(detail=True, methods=['get'])
    def quizzes(self, request, pk=None):
        lesson = self.get_object()
        # Vérifier l'accès à la leçon avant de retourner les quizzes
        if not is_lesson_unlocked_for_user(request.user, lesson):
            return Response(
                {'detail': 'Vous n\'avez pas accès aux quiz de cette leçon.'},
                status=status.HTTP_403_FORBIDDEN
            )
        quizzes = lesson.quizzes.all()
        serializer = QuizSerializer(quizzes, many=True)
        return Response(serializer.data)

class QuizViewSet(viewsets.ReadOnlyModelViewSet):
    queryset = Quiz.objects.all()
    serializer_class = QuizSerializer
    permission_classes = [IsAuthenticated, IsQuizUnlockedPermission]
    
    @action(detail=True, methods=['post'])
    def submit_answer(self, request, pk=None):
        quiz = self.get_object()
        choice_id = request.data.get('choice_id')
        
        try:
            choice = QuizChoice.objects.get(id=choice_id, quiz=quiz)
            is_correct = choice.is_correct
            points = quiz.points if is_correct else 0
            
            attempt = QuizAttempt.objects.create(
                user=request.user,
                quiz=quiz,
                selected_choice=choice,
                is_correct=is_correct,
                points_earned=points
            )
            
            if is_correct:
                profile = request.user.profile
                profile.add_points(points)
            
            return Response({
                'is_correct': is_correct,
                'points_earned': points,
                'correct_answer': quiz.choices.filter(is_correct=True).first().choice_text if not is_correct else None
            })
        except QuizChoice.DoesNotExist:
            return Response({'error': 'Choix invalide'}, status=status.HTTP_400_BAD_REQUEST)

class UserProfileViewSet(viewsets.ReadOnlyModelViewSet):
    queryset = UserProfile.objects.all()
    serializer_class = UserProfileSerializer
    permission_classes = [IsAuthenticated]
    
    @action(detail=False, methods=['get'])
    def me(self, request):
        profile = request.user.profile
        serializer = self.get_serializer(profile)
        return Response(serializer.data)

class GameScoreViewSet(viewsets.ModelViewSet):
    queryset = GameScore.objects.all()
    serializer_class = GameScoreSerializer
    permission_classes = [IsAuthenticated]
    
    def perform_create(self, serializer):
        game_score = serializer.save(user=self.request.user)
        if game_score.points_earned > 0:
            profile = self.request.user.profile
            profile.add_points(game_score.points_earned)


