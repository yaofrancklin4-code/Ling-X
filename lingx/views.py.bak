@login_required
def community_view(request):
    # Filtrer par rôle
    role_filter = request.GET.get('role', 'all')
    
    if role_filter == 'teacher':
        profiles = UserProfile.objects.filter(role='teacher', is_verified=True, is_available=True)
    elif role_filter == 'avance':
        profiles = UserProfile.objects.filter(role='avance', is_verified=True, is_available=True)
    elif role_filter == 'student':
        profiles = UserProfile.objects.filter(role='student', is_available=True)
    else:
        profiles = UserProfile.objects.filter(is_available=True)
    
    # Exclure l'utilisateur actuel
    profiles = profiles.exclude(user=request.user).order_by('-total_points')
    
    # Séparer par catégories
    teachers = UserProfile.objects.filter(role='teacher', is_verified=True, is_available=True).exclude(user=request.user)[:6]
    experts = UserProfile.objects.filter(role='avance', is_verified=True, is_available=True).exclude(user=request.user)[:6]
    students = UserProfile.objects.filter(role='student', is_available=True).exclude(user=request.user).order_by('-total_points')[:12]
    
    context = {
        'profiles': profiles,
        'teachers': teachers,
        'experts': experts,
        'students': students,
        'role_filter': role_filter,
    }
    return render(request, 'community.html', context)

