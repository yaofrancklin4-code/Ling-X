# ============= PERMISSIONS PERSONNALISÉES =============
class IsLessonUnlockedPermission(BasePermission):
    """Vérifie que l'utilisateur a accès à la leçon basée sur son niveau"""
    
    def has_object_permission(self, request, view, obj):
        # obj est la leçon
        if not isinstance(obj, Lesson):
            return True
        return is_lesson_unlocked_for_user(request.user, obj)


class IsQuizUnlockedPermission(BasePermission):
    """Vérifie que l'utilisateur a accès au quiz basée sur son niveau"""
    
    def has_object_permission(self, request, view, obj):
        # obj est le quiz
        if not isinstance(obj, Quiz):
            return True
        return is_test_unlocked_for_user(request.user, obj)


def is_lesson_unlocked(user_level, lesson_number):
    """Vérifie si une leçon est débloquée selon le niveau utilisateur.
    
    Une leçon est débloquée si son numéro <= niveau utilisateur.
    """
    if lesson_number is None or lesson_number <= 0:
        return False
    return lesson_number <= max(1, user_level)


def is_test_unlocked(user_level, test_number):
    """Vérifie si un test est débloqué selon le niveau utilisateur.
    
    Un test est débloqué si son numéro <= niveau utilisateur.
    """
    if test_number is None or test_number <= 0:
        return False
    return test_number <= max(1, user_level)


def is_lesson_unlocked_for_user(user, lesson):
    """Vérifie si une leçon est accessible pour l'utilisateur actuel.
    
    Utilise lesson.number directement. Si non défini, retourne False (verrouillé).
    """
    try:
        user_level = int(user.profile.level)
    except Exception:
        user_level = 1

    lesson_number = lesson.number if hasattr(lesson, 'number') and lesson.number else None
    return is_lesson_unlocked(user_level, lesson_number)


def is_test_unlocked_for_user(user, quiz):
    """Vérifie si un test est accessible pour l'utilisateur actuel.
    
    Utilise quiz.number directement. Si non défini, retourne False (verrouillé).
    """
    try:
        user_level = int(user.profile.level)
    except Exception:
        user_level = 1

    quiz_number = quiz.number if hasattr(quiz, 'number') and quiz.number else None
    return is_test_unlocked(user_level, quiz_number)


def is_game_unlocked_for_user(user, game):
    """Vérifie si un jeu est accessible pour l'utilisateur actuel.
    
    Un jeu est débloqué si sa leçon associée est débloquée.
    """
    if not game.lesson:
        return True  # Jeu sans leçon = toujours accessible
    return is_lesson_unlocked_for_user(user, game.lesson)

