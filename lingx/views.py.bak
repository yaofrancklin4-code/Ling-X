def home(request):
    categories = Category.objects.all()[:6]
    total_users = User.objects.count()
    total_lessons = Lesson.objects.count()
    total_words = Vocabulary.objects.count()
    context = {
        'categories': categories,
        'total_users': total_users,
        'total_lessons': total_lessons,
        'total_words': total_words,
    }
    return render(request, 'home.html', context)

def register_view(request):
    if request.method == 'POST':
        username = request.POST.get('username')
        email = request.POST.get('email')
        password = request.POST.get('password')
        password2 = request.POST.get('password2')
        
        if password != password2:
            messages.error(request, 'Les mots de passe ne correspondent pas')
            return redirect('register')
        
        if User.objects.filter(username=username).exists():
            messages.error(request, 'Ce nom d\'utilisateur existe déjà')
            return redirect('register')
        
        if User.objects.filter(email=email).exists():
            messages.error(request, 'Cet email est déjà utilisé')
            return redirect('register')
        
        user = User.objects.create_user(username=username, email=email, password=password)
        # Le UserProfile est créé automatiquement par le signal post_save dans signals.py
        # Spécifier le backend d'authentification (plusieurs backends sont configurés)
        user.backend = 'django.contrib.auth.backends.ModelBackend'
        login(request, user)
        messages.success(request, 'Compte créé avec succès!')
        return redirect('dashboard')
    
    return render(request, 'register.html')

def login_view(request):
    if request.method == 'POST':
        username = request.POST.get('username')
        password = request.POST.get('password')
        user = authenticate(request, username=username, password=password)
        
        if user is not None:
            # Le backend est automatiquement défini par authenticate(), mais on l'ajoute explicitement
            user.backend = 'django.contrib.auth.backends.ModelBackend'
            login(request, user)
            messages.success(request, f'Bienvenue {username}!')
            return redirect('dashboard')
        else:
            messages.error(request, 'Identifiants incorrects')
    
    return render(request, 'login.html')

def logout_view(request):
    logout(request)
    messages.success(request, 'Déconnexion réussie')
    return redirect('home')

@login_required
def dashboard(request):
    profile = request.user.profile
    recent_progress = LessonProgress.objects.filter(user=request.user).order_by('-updated_at')[:5]
    
    # Statistiques
    total_lessons_completed = LessonProgress.objects.filter(user=request.user, is_completed=True).count()
    total_quizzes = QuizAttempt.objects.filter(user=request.user).count()
    success_rate = 0
    if total_quizzes > 0:
        correct_quizzes = QuizAttempt.objects.filter(user=request.user, is_correct=True).count()
        success_rate = int((correct_quizzes / total_quizzes) * 100)
    
    context = {
        'profile': profile,
        'recent_progress': recent_progress,
        'total_lessons_completed': total_lessons_completed,
        'total_quizzes': total_quizzes,
        'success_rate': success_rate,
    }
    return render(request, 'dashboard.html', context)

@login_required
def categories_view(request):
    categories = Category.objects.annotate(lesson_count=Count('lessons'))
    context = {'categories': categories}
    return render(request, 'categories.html', context)

@login_required
def category_detail(request, category_id):
    category = get_object_or_404(Category, id=category_id)
    lessons = category.lessons.all().order_by('order')
    
    # Récupérer le niveau de l'utilisateur
    user_level = int(request.user.profile.level) if hasattr(request.user, 'profile') else 1
    
    # Marquer les leçons complétées et calculer l'état de verrouillage
    for lesson in lessons:
        progress = LessonProgress.objects.filter(user=request.user, lesson=lesson).first()
        lesson.is_completed = progress.is_completed if progress else False
        lesson.user_score = progress.score if progress else 0
        
        # Verrouillage selon le niveau de l'utilisateur
        try:
            lesson.is_locked = not is_lesson_unlocked_for_user(request.user, lesson)
            # Ajouter des infos de déblocage
            lesson.required_level = lesson.number
            lesson.next_unlock_level = lesson.number + 1 if lesson.is_locked else None
        except Exception:
            lesson.is_locked = False
            lesson.required_level = lesson.number
            lesson.next_unlock_level = None
    
    context = {
        'category': category,
        'lessons': lessons,
        'user_level': user_level,
    }
    return render(request, 'category_detail.html', context)

@login_required
def lesson_detail(request, lesson_id):
    lesson = get_object_or_404(Lesson, id=lesson_id)
    
    # Récupérer le niveau de l'utilisateur
    try:
        user_level = int(request.user.profile.level)
    except (AttributeError, ValueError):
        user_level = 1
    
    # Vérifier accès selon niveau - PROTECTION STRICTE
    unlocked = is_lesson_unlocked_for_user(request.user, lesson)
    
    if not unlocked:
        # Accès refusé - afficher la page verrouillée
        progress, created = LessonProgress.objects.get_or_create(
            user=request.user,
            lesson=lesson
        )
        
        # Calculer le numéro de la leçon précédente à débloquer
        previous_lesson_number = lesson.number - 1 if lesson.number > 1 else 0
        
        context = {
            'lesson': lesson,
            'vocabularies': [],
            'quizzes': [],
            'progress': progress,
            'locked': True,
            'user_level': user_level,
            'required_level': lesson.number,
            'previous_lesson_number': previous_lesson_number,
        }
        return render(request, 'lesson_detail.html', context)

    # Accès autorisé
    vocabularies = lesson.vocabularies.all()
    quizzes = lesson.quizzes.all()
    
    progress, created = LessonProgress.objects.get_or_create(
        user=request.user,
        lesson=lesson
    )
    
    context = {
        'lesson': lesson,
        'vocabularies': vocabularies,
        'quizzes': quizzes,
        'progress': progress,
        'locked': False,
        'user_level': user_level,
        'required_level': lesson.number,
    }
    return render(request, 'lesson_detail.html', context)

@login_required
def quiz_view(request, lesson_id):
    lesson = get_object_or_404(Lesson, id=lesson_id)
    # Bloquer l'accès si la leçon n'est pas déverrouillée pour l'utilisateur
    if not is_lesson_unlocked_for_user(request.user, lesson):
        messages.error(request, 'Cette leçon est verrouillée pour votre niveau. Terminez les leçons précédentes pour y accéder.')
        return redirect('lesson_detail', lesson_id=lesson.id)

    quizzes = lesson.quizzes.all()
    
    if request.method == 'POST':
        score = 0
        total_points = 0
        
        for quiz in quizzes:
            # Vérifier que le test est déverrouillé avant de traiter
            if not is_test_unlocked_for_user(request.user, quiz):
                messages.error(request, f'Le test "{quiz.question[:50]}" n\'est pas déverrouillé.')
                return redirect('lesson_detail', lesson_id=lesson.id)
            
            choice_id = request.POST.get(f'quiz_{quiz.id}')
            if choice_id:
                choice = QuizChoice.objects.get(id=choice_id)
                is_correct = choice.is_correct
                points = quiz.points if is_correct else 0
                
                QuizAttempt.objects.create(
                    user=request.user,
                    quiz=quiz,
                    selected_choice=choice,
                    is_correct=is_correct,
                    points_earned=points
                )
                
                if is_correct:
                    score += points
                    total_points += points
        
        # Mettre à jour la progression
        progress, created = LessonProgress.objects.get_or_create(
            user=request.user,
            lesson=lesson
        )
        progress.score = max(progress.score, score)
        progress.attempts += 1
        
        was_completed = progress.is_completed
        
        if score >= (lesson.points * 0.7):  # 70% pour réussir
            progress.is_completed = True
            progress.completed_at = timezone.now()
        
        progress.save()
        
        # Ajouter des points au profil
        profile = request.user.profile
        profile.add_points(total_points)
        
        # Si la leçon vient d'être validée pour la première fois et a un numéro
        # augmenter le niveau pour débloquer la leçon suivante
        if progress.is_completed and not was_completed and lesson.number:
            # Le niveau doit être au minimum lesson.number + 1 pour débloquer la leçon suivante
            next_level = lesson.number + 1
            if profile.level < next_level:
                profile.level = next_level
                profile.save()
                messages.success(request, f'🎉 Bravo! Vous êtes passé au Niveau {next_level}!')
        
        
        messages.success(request, f'Quiz terminé! Score: {score} points')
        return redirect('lesson_detail', lesson_id=lesson.id)
    
    context = {
        'lesson': lesson,
        'quizzes': quizzes,
    }
    return render(request, 'quiz.html', context)

@login_required
def tests_list(request):
    """Affiche la liste de tous les tests (quizzes) avec état de déblocage"""
    # Afficher TOUTES les leçons avec leurs tests (déverrouillés ou non)
    lessons = Lesson.objects.all().order_by('number')
    lessons_with_quizzes = []
    
    # Récupérer le niveau de l'utilisateur
    try:
        user_level = int(request.user.profile.level)
    except (AttributeError, ValueError):
        user_level = 1
    
    for lesson in lessons:
        quizzes = lesson.quizzes.all()
        if quizzes.exists():
            # Récupérer le meilleur score de l'utilisateur pour cette leçon
            best_attempt = QuizAttempt.objects.filter(
                user=request.user,
                quiz__lesson=lesson
            ).order_by('-points_earned').first()

            # Préparer la liste des quizzes avec état de déblocage
            quiz_list = []
            for quiz in quizzes.order_by('number'):
                quiz_list.append({
                    'quiz': quiz,
                    'unlocked': is_test_unlocked_for_user(request.user, quiz)
                })
            
            lessons_with_quizzes.append({
                'lesson': lesson,
                'quiz_count': quizzes.count(),
                'best_score': best_attempt.points_earned if best_attempt else 0,
                'attempts': QuizAttempt.objects.filter(
                    user=request.user,
                    quiz__lesson=lesson
                ).count(),
                'quizzes': quiz_list,
                'lesson_unlocked': is_lesson_unlocked_for_user(request.user, lesson),
                'required_level': lesson.number,
            })
    
    context = {
        'lessons_with_quizzes': lessons_with_quizzes,
        'user_level': user_level,
    }
    return render(request, 'tests_list.html', context)

@login_required
def games_view(request):
    games = MiniGame.objects.filter(is_active=True)
    user_scores = GameScore.objects.filter(user=request.user).order_by('-created_at')[:10]
    
    # Ajouter les informations de déblocage pour chaque jeu
    games_with_unlock = []
